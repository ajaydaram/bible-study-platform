# Firebase Configuration
# Get these from https://console.firebase.google.com > Project Settings > Your apps

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# BibleBrain API (Audio Bible)
# Request a free API key at: https://4.dbt.io/api_key/request
# Documentation: https://www.faithcomesbyhearing.com/bible-brain/developer-documentation
VITE_BIBLE_BRAIN_KEY=your_bible_brain_api_key_here

# ESV API (Optional - for ESV translation)
# Get your API key from: https://api.esv.org/account/create-application/
VITE_ESV_API_KEY=your_esv_api_key_here

# ============================================
# SECURITY & MONITORING (Optional but recommended)
# ============================================

# Firebase App Check - Protects your APIs from abuse
# 1. Go to Firebase Console > App Check
# 2. Register your app with reCAPTCHA Enterprise
# 3. Get your site key from Google Cloud Console
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Sentry Error Tracking
# 1. Create account at https://sentry.io
# 2. Create a new React project
# 3. Copy the DSN from Project Settings
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id